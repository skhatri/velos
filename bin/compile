#!/bin/bash
set -e
DIR="$( cd "$( dirname "${BASH_SOURCE[0]}" )" && pwd )"
SPEC=$1
OUT=$2
OUT_VALUES=$3

if [ -z "$SPEC" ] || [ -z "$OUT" ]; then
    echo "Usage: compile <spec.yaml> <output-compose.yml> [output-values.yaml]"
    exit 1
fi

PYTHON="python3"
if ! python3 -c "import yaml" &> /dev/null; then
    VENV_DIR="$DIR/../.venv"
    if [ ! -d "$VENV_DIR" ]; then
        python3 -m venv "$VENV_DIR"
        "$VENV_DIR/bin/pip" install pyyaml > /dev/null 2>&1
    fi
    PYTHON="$VENV_DIR/bin/python"
fi

if [ -n "$OUT_VALUES" ]; then
    $PYTHON "$DIR/../generate.py" "$SPEC" "$OUT" "$OUT_VALUES"
    echo "✅ Compiled $OUT and $OUT_VALUES"
else
    $PYTHON "$DIR/../generate.py" "$SPEC" "$OUT"
    echo "✅ Compiled $OUT"
fi
